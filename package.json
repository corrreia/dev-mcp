{
  "name": "dev-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 8787",
    "build": "npm run cf-typegen && vite build",
    "preview": "npm run build && wrangler dev --config dist/server/wrangler.json",
    "deploy": "npm run build && wrangler deploy --config dist/server/wrangler.json",
    "cf-typegen": "wrangler types worker-configuration.d.ts",
    "check-types": "npm run cf-typegen && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply dev-mcp --local",
    "db:migrate:remote": "wrangler d1 migrations apply dev-mcp --remote"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@cloudflare/codemode": "^0.2.1",
    "@cloudflare/vite-plugin": "^1.35.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-start": "^1.167.62",
    "ai": "^6.0.175",
    "better-auth": "^1.6.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wrangler": "^4.40.0"
  },
  "overrides": {
    "esbuild": "0.27.7"
  }
}
